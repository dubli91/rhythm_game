{
  "name": "prismbeat",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "description": "Browser-only 7-key + turntable rhythm game (TypeScript + Vite + PixiJS + Web Audio)",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "validate:songs": "vite-node scripts/validate-songs.ts",
    "typecheck": "tsc --noEmit",
    "lint": "biome check .",
    "format": "biome format --write ."
  },
  "dependencies": {
    "pixi.js": "^8.6.6"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@types/node": "^26.1.1",
    "fake-indexeddb": "^6.0.0",
    "playwright": "^1.61.1",
    "typescript": "^5.7.3",
    "vite": "^6.0.11",
    "vitest": "^3.0.5",
    "wasm-media-encoders": "^0.7.0"
  }
}
